{% extends 'base.html.twig' %}

{% block body %}
<div class="flex h-full min-h-screen">
    {# Sidebar Navigation #}
    <nav class="sidebar w-64 flex-shrink-0 flex flex-col py-8 px-4" style="background: #0f1223; border-right: 1px solid rgba(245,158,11,0.12);">
        {# Logo #}
        <a href="{{ path('dashboard') }}" class="flex items-center gap-3 px-3 mb-10 group">
            <div class="w-8 h-8 flex-shrink-0">
                <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M4 16 Q8 8 16 16 Q24 24 28 16" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round" fill="none"/>
                    <circle cx="4" cy="16" r="2" fill="#f59e0b"/>
                    <circle cx="28" cy="16" r="2" fill="#f59e0b"/>
                </svg>
            </div>
            <span class="font-serif text-xl font-semibold text-amber-400 group-hover:text-amber-300 transition-colors">Selftrace</span>
        </a>

        {# User greeting #}
        <div class="px-3 mb-8">
            <p class="text-xs text-stone-500 uppercase tracking-wider mb-1">Welcome back</p>
            <p class="text-sm text-stone-300 truncate">{{ app.user.username }}</p>
        </div>

        {# Navigation links #}
        <ul class="space-y-1 flex-1">
            {% set current_route = app.request.attributes.get('_route') ?? '' %}
            {% set nav_items = [
                { route: 'dashboard', href: path('dashboard'), label: 'Dashboard', icon: 'home', prefix: 'dashboard' },
                { route: 'timeline_index', href: path('timeline_index'), label: 'My Timeline', icon: 'timeline', prefix: 'timeline' },
                { route: 'parts_index', href: path('parts_index'), label: 'My Parts', icon: 'parts', prefix: 'parts' },
                { route: 'reflections_index', href: path('reflections_index'), label: 'Daily Reflection', icon: 'reflection', prefix: 'reflections' },
                { route: 'patterns_index', href: path('patterns_index'), label: 'Patterns', icon: 'patterns', prefix: 'patterns' },
            ] %}

            {% for item in nav_items %}
                {% set is_active = current_route starts with item.prefix %}
                <li>
                    <a href="{{ item.href }}"
                       class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all duration-200 text-sm
                              {{ is_active ? 'text-amber-400 bg-amber-400/10 font-medium' : 'text-stone-400 hover:text-stone-200 hover:bg-white/5' }}">
                        <span class="nav-icon w-5 h-5 flex-shrink-0">
                            {{ include('_icons/' ~ item.icon ~ '.html.twig') }}
                        </span>
                        {{ item.label }}
                    </a>
                </li>
            {% endfor %}
        </ul>

        {# Bottom links #}
        <div class="mt-auto space-y-1 border-t border-white/5 pt-4">
            <a href="{{ path('profile') }}" class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-stone-400 hover:text-stone-200 hover:bg-white/5 transition-all duration-200">
                <span class="w-5 h-5 flex-shrink-0">{{ include('_icons/profile.html.twig') }}</span>
                Profile
            </a>
            <a href="{{ path('security_logout') }}" class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-stone-400 hover:text-stone-200 hover:bg-white/5 transition-all duration-200">
                <span class="w-5 h-5 flex-shrink-0">{{ include('_icons/logout.html.twig') }}</span>
                Sign out
            </a>
        </div>
    </nav>

    {# Backdrop for mobile sidebar #}
    <div id="sidebar-backdrop"
         class="hidden fixed inset-0 z-40 bg-black/60"
         onclick="closeSidebar()"></div>

    {# Main content #}
    <main class="flex-1 overflow-y-auto min-w-0">

        {# Mobile top bar #}
        <div class="md:hidden flex items-center justify-between px-4 py-3 sticky top-0 z-30"
             style="background: #0f1223; border-bottom: 1px solid rgba(245,158,11,0.12);">
            <button onclick="openSidebar()" class="p-2 rounded-lg text-stone-400 hover:text-stone-200 hover:bg-white/5 transition-colors" aria-label="Open menu">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>
            <a href="{{ path('dashboard') }}" class="flex items-center gap-2">
                <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6">
                    <path d="M4 16 Q8 8 16 16 Q24 24 28 16" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round" fill="none"/>
                    <circle cx="4" cy="16" r="2" fill="#f59e0b"/>
                    <circle cx="28" cy="16" r="2" fill="#f59e0b"/>
                </svg>
                <span class="font-serif text-lg font-semibold text-amber-400">Selftrace</span>
            </a>
            <div class="w-9"></div>{# spacer to centre the logo #}
        </div>

        {# Flash messages #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash-message flash-{{ type }} fixed top-4 right-4 z-50 px-5 py-3 rounded-lg text-sm font-medium shadow-xl
                            {{ type == 'success' ? 'bg-emerald-900/90 text-emerald-200 border border-emerald-700/50' : 'bg-red-900/90 text-red-200 border border-red-700/50' }}"
                     data-auto-dismiss>
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <div class="max-w-5xl mx-auto px-6 py-10">
            {% block content %}{% endblock %}
        </div>
    </main>
</div>

<script>
function openSidebar() {
    document.querySelector('.sidebar').classList.add('mobile-open');
    document.getElementById('sidebar-backdrop').classList.remove('hidden');
    document.body.style.overflow = 'hidden';
}
function closeSidebar() {
    document.querySelector('.sidebar').classList.remove('mobile-open');
    document.getElementById('sidebar-backdrop').classList.add('hidden');
    document.body.style.overflow = '';
}
// Close sidebar when a nav link is tapped on mobile
document.querySelectorAll('.sidebar .nav-link').forEach(function(link) {
    link.addEventListener('click', closeSidebar);
});

// Global tooltip for [data-tooltip] elements
(function() {
    const tip = document.createElement('div');
    tip.id = 'ui-tooltip';
    tip.style.opacity = '0';
    document.body.appendChild(tip);

    document.addEventListener('mouseover', function(e) {
        const el = e.target.closest('[data-tooltip]');
        if (!el) return;
        tip.textContent = el.dataset.tooltip;
        tip.style.opacity = '1';
    });
    document.addEventListener('mouseout', function(e) {
        const el = e.target.closest('[data-tooltip]');
        if (!el) return;
        tip.style.opacity = '0';
    });
    document.addEventListener('mousemove', function(e) {
        tip.style.left = (e.clientX - tip.offsetWidth / 2) + 'px';
        tip.style.top = (e.clientY - tip.offsetHeight - 10) + 'px';
    });
})();
</script>
{% endblock %}
