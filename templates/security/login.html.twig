{% extends 'base.html.twig' %}

{% block title %}Sign in — Selftrace{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center px-4 py-12" style="background: #0d0f1a;">
    <div class="w-full max-w-md">
        {# Logo #}
        <div class="text-center mb-10">
            <a href="{{ path('app_landing') }}" class="inline-flex items-center gap-3 group">
                <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-8 h-8">
                    <path d="M4 16 Q8 8 16 16 Q24 24 28 16" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round" fill="none"/>
                    <circle cx="4" cy="16" r="2" fill="#f59e0b"/>
                    <circle cx="28" cy="16" r="2" fill="#f59e0b"/>
                </svg>
                <span class="font-serif text-2xl font-semibold text-amber-400">Selftrace</span>
            </a>
            <p class="text-stone-500 text-sm mt-3">Welcome back</p>
        </div>

        {# Flash messages #}
        {% for message in app.flashes('success') %}
            <div class="mb-6 px-4 py-3 rounded-lg bg-emerald-900/40 border border-emerald-700/40 text-emerald-300 text-sm">
                {{ message }}
            </div>
        {% endfor %}

        {# Error #}
        {% if error %}
            <div class="mb-6 px-4 py-3 rounded-lg bg-red-900/40 border border-red-700/40 text-red-300 text-sm">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {# Form card #}
        <div class="rounded-2xl p-8" style="background: #131628; border: 1px solid rgba(255,255,255,0.06);">
            <form method="post" action="{{ path('security_login') }}">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="mb-5">
                    <label for="username" class="block text-sm font-medium text-stone-400 mb-2">Username</label>
                    <input type="text" id="username" name="_username"
                           value="{{ last_username }}"
                           autocomplete="username"
                           class="form-input w-full px-4 py-3 rounded-xl text-stone-100 text-sm placeholder-stone-600 transition-all"
                           style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);"
                           placeholder="your_username"
                           autofocus>
                </div>

                <div class="mb-6">
                    <label for="password" class="block text-sm font-medium text-stone-400 mb-2">Password</label>
                    <input type="password" id="password" name="_password"
                           autocomplete="current-password"
                           class="form-input w-full px-4 py-3 rounded-xl text-stone-100 text-sm placeholder-stone-600 transition-all"
                           style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);"
                           placeholder="••••••••">
                </div>

                <div class="flex items-center mb-6">
                    <input type="checkbox" id="remember_me" name="_remember_me"
                           class="w-4 h-4 rounded accent-amber-500">
                    <label for="remember_me" class="ml-2 text-sm text-stone-400">Remember me</label>
                </div>

                <button type="submit"
                        class="w-full py-3 px-6 rounded-xl font-medium text-sm btn-amber">
                    Sign in
                </button>
            </form>
        </div>

        <p class="text-center text-stone-500 text-sm mt-6">
            New here?
            <a href="{{ path('security_register') }}" class="text-amber-400 hover:text-amber-300 transition-colors">Create an account</a>
        </p>
    </div>
</div>
{% endblock %}
