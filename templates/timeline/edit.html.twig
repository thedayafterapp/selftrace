{% extends 'layout.html.twig' %}

{% block title %}Edit Chapter — Selftrace{% endblock %}

{% block content %}
<div class="max-w-2xl space-y-6">
    <div>
        <a href="{{ path('timeline_index') }}" class="text-sm text-stone-500 hover:text-stone-300 transition-colors flex items-center gap-1 mb-6">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
            </svg>
            Back to timeline
        </a>
        <h1 class="font-serif text-3xl mb-1" style="color: #f0ede8;">Edit chapter</h1>
        <p class="text-stone-500 font-serif text-lg text-amber-400/80">{{ chapter.title }}</p>
    </div>

    {{ include('timeline/_form.html.twig') }}
</div>
{% endblock %}
